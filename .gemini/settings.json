{
  "hooks": {
    "BeforeAgent": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "ai-log-prompt",
            "type": "command",
            "command": "bash \"$GEMINI_PROJECT_DIR/scripts/run_log_hook.sh\"",
            "timeout": 15000
          }
        ]
      }
    ],
    "AfterAgent": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "ai-log-after-agent",
            "type": "command",
            "command": "bash \"$GEMINI_PROJECT_DIR/scripts/run_log_hook.sh\"",
            "timeout": 15000
          }
        ]
      }
    ]
  }
}
