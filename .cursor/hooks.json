{
  "version": 1,
  "hooks": {
    "beforeSubmitPrompt": [
      {
        "command": ".cursor/hooks/log_hook_runner.cmd"
      }
    ],
    "userPromptSubmitted": [
      {
        "command": ".cursor/hooks/log_hook_runner.cmd"
      }
    ],
    "userPromptSubmit": [
      {
        "command": ".cursor/hooks/log_hook_runner.cmd"
      }
    ],
    "stop": [
      {
        "command": ".cursor/hooks/log_hook_runner.cmd"
      }
    ]
  }
}
