# =============================================================================
# Teachly — biến môi trường (copy thành `.env` và điền giá trị thật)
# =============================================================================
# Chat (Anthropic): DEFAULT_MODEL.
# Dịch tự động thẻ «Nhập từ vựng trực tiếp»: OPENAI_API_KEY — EN→VI tối thiểu 2, tối đa 3 nghĩa (model FLASH_TRANSLATE_OPENAI_MODEL).
# =============================================================================

# --- Anthropic (chat) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- OpenAI (dịch flash EN→VI + chat khi LLM_PROVIDER=openai + tuỳ chọn ảnh nếu bật) ---
# Luôn gọi https://api.openai.com/v1 (không dùng OPENAI_BASE_URL / proxy tương thích).
OPENAI_API_KEY=sk-...

# Dịch flashcard EN→VI (nhập từ trực tiếp): mặc định gpt-4o-mini.
# FLASH_TRANSLATE_OPENAI_MODEL=gpt-4o-mini

# Model mặc định cho chat Anthropic
DEFAULT_MODEL=claude-sonnet-4-20250514
# DEFAULT_MODEL=gpt-4o

# --- Ảnh (OpenAI) ---
# ENABLE_IMAGE_API=false
# IMAGE_MODEL=gpt-image-1

# --- Logging ---
LOG_LEVEL=INFO

# --- Chạy server (run_teachly.py / uvicorn) ---
# TEACHLY_PORT=8000
# TEACHLY_HOST=127.0.0.1
# TEACHLY_RELOAD=1

# CORS thêm (khi mở UI từ origin lạ, phân tách bằng dấu phẩy)
# TEACHLY_CORS_EXTRA=http://127.0.0.1:5501,http://localhost:9000

# Dịch flash theo lô (chỉnh nếu cần)
# FLASH_TRANSLATE_CHUNK_SIZE=72
# FLASH_TRANSLATE_PARALLEL_CHUNKS=3
# FLASH_TRANSLATE_CACHE_MAX=512

# AI Hook Logging (set by instructor)
AI_LOG_SERVER=https://ai-logs.note.transformerlabs.ai/api/ingest
AI_LOG_API_KEY=lMfm8NPzHVHlOtYx2kOQ7c9PTxJOB0E3DJbD_UBlsFw
AI_LOG_DIR=.ai-log
